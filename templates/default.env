# Card background and text
DARK_CARD_BG=#220033
DARK_CARD_FG=#FFCCDD

LIGHT_CARD_BG=#FFDDEE
LIGHT_CARD_FG=#110022

# Heading/title color
DARK_HEAD_FG=#5511DD
LIGHT_HEAD_FG=#3300FF

# Language pill (rect) colors
DARK_LANG_BG=#5511DD
DARK_LANG_BORDER=#330055
DARK_LANG_FG=$DARK_CARD_FG
DARK_LANG_BORDER_WIDTH=8
DARK_LANG_RADIUS=24

LIGHT_LANG_BG=#3300FF
LIGHT_LANG_BORDER=#FFCCDD
LIGHT_LANG_FG=$LIGHT_CARD_BG
LIGHT_LANG_BORDER_WIDTH=8
LIGHT_LANG_RADIUS=24

# Stat text color
DARK_STAT_FG=$DARK_CARD_FG
LIGHT_STAT_FG=$LIGHT_CARD_FG

